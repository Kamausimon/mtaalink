# ─────────────────────────────────────────────────────────────────────────────
# MtaaLink Backend — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# Server
PORT=7878

# FRONTEND_URL accepts comma-separated origins.
# Local dev:
FRONTEND_URL=http://localhost:3000
# Production (Railway): set this to your Vercel URL, e.g.:
# FRONTEND_URL=https://mtaalink.vercel.app,http://localhost:3000

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Works with Gmail app passwords, Mailgun, Resend SMTP relay, SendGrid, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password   # 16-char Google app password (not your login password)
SMTP_FROM=noreply@mtaalink.co.ke

# ─── SMS — Africa's Talking ──────────────────────────────────────────────────
# Sign up at https://africastalking.com
AT_API_KEY=your_api_key
AT_USERNAME=sandbox                 # use "sandbox" for testing, your username for production
AT_SENDER_ID=MTAALINK               # must be approved by AT in production

# ─── M-Pesa (Daraja API) ─────────────────────────────────────────────────────
# Get credentials at https://developer.safaricom.co.ke
MPESA_ENV=sandbox                   # "sandbox" or "production"
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379              # sandbox test shortcode
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Must be a public HTTPS URL — use ngrok locally, Railway URL in production:
MPESA_CALLBACK_URL=https://your-backend.railway.app/payments/mpesa/callback

# ─── File storage ────────────────────────────────────────────────────────────
# "local" serves from ./uploads (dev only). Use "s3" in production.
STORAGE_BACKEND=local

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=mtaalink-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BASE_URL=https://mtaalink-uploads.s3.us-east-1.amazonaws.com
