# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/mtaalink

# Server
PORT=7878
FRONTEND_URL=http://localhost:5173

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here

# Email (SMTP) — works with Gmail app password, Mailgun, SendGrid SMTP relay, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@mtaalink.com
FROM_NAME=MtaaLink

# App base URL (used to build password reset links in emails)
APP_URL=http://localhost:7878

# SMS — Africa's Talking (https://africastalking.com)
AT_ENV=sandbox           # "sandbox" or "production"
AT_API_KEY=your_api_key
AT_USERNAME=sandbox      # your AT account username (use "sandbox" for testing)
AT_SENDER_ID=MTAALINK    # optional — must be approved by AT for production

# M-Pesa (Daraja API)
# Get credentials from https://developer.safaricom.co.ke
MPESA_ENV=sandbox                          # "sandbox" or "production"
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                     # sandbox test shortcode
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919  # sandbox passkey
MPESA_CALLBACK_URL=https://your-domain.com/payments/mpesa/callback

# Storage backend: "local" (default) or "s3"
STORAGE_BACKEND=local

# AWS S3 (only required when STORAGE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=mtaalink-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BASE_URL=https://mtaalink-uploads.s3.us-east-1.amazonaws.com
