# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/mtaalink

# Server
PORT=7878
FRONTEND_URL=http://localhost:5173

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here

# Email (SMTP) — works with Gmail app password, Mailgun, SendGrid SMTP relay, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@mtaalink.com
FROM_NAME=MtaaLink

# App base URL (used to build password reset links in emails)
APP_URL=http://localhost:7878

# Storage backend: "local" (default) or "s3"
STORAGE_BACKEND=local

# AWS S3 (only required when STORAGE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=mtaalink-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BASE_URL=https://mtaalink-uploads.s3.us-east-1.amazonaws.com
